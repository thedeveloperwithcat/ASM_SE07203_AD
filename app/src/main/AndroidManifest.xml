<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SE07203B5"
        tools:targetApi="31">

        <!-- Trang đăng ký -->
        <activity
            android:name=".RegisterActivity"
            android:exported="false" />

        <!-- Trang đăng nhập -->
        <activity
            android:name=".LoginActivity"
            android:exported="false" />

        <!-- Trang tạo task mới -->
        <activity
            android:name=".CreateNewTaskActivity"
            android:exported="false" />

        <!-- Trang chính của app: LÀ LAUNCHER -->
        <activity
            android:name=".MainActivity"
            android:exported="true">

            <!-- Chỉ MainActivity được làm MAIN + LAUNCHER -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Trang MonthlyPurchases: CHỈ LÀ TRANG PHỤ, KHÔNG LAUNCHER -->
        <activity
            android:name=".MonthlyPurchases"
            android:exported="false" />

    </application>

</manifest>
